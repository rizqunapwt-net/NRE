APP_NAME="Rizquna ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default local DB: SQLite (no external service needed).
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# PostgreSQL example (production):
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=rizquna_erp
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# MySQL example:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=rizquna_erp
# DB_USERNAME=root
# DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Redis (recommended for production):
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@rizquna.id"
MAIL_FROM_NAME="${APP_NAME}"

# Production Mail (example):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@rizquna.id
# MAIL_FROM_NAME="${APP_NAME}"

# S3 (optional for file storage):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=ap-southeast-3
# AWS_BUCKET=your-bucket
# AWS_ENDPOINT=https://your-s3-endpoint.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000
FRONTEND_URL=http://localhost:8000

# n8n webhook (optional):
N8N_CONTRACT_EXPIRY_WEBHOOK=

# Sentry (optional error tracking):
# SENTRY_LARAVEL_DSN=https://your-sentry-dsn
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENABLE_LOGS=false

# CSP (Content Security Policy) - Report Only mode:
# Set to true to enable CSP monitoring without blocking
ERP_CSP_REPORT_ONLY=false
# CSP_REPORT_URI=https://your-csp-report-endpoint.com

# Production Security (optional):
# TRUSTED_PROXIES=*
# TRUSTED_HEADERS=X-Forwarded-For,X-Forwarded-Host,X-Forwarded-Proto

# Horizon (queue monitoring):
# HORIZON_DOMAIN=localhost:8000
# HORIZON_MIDDLEWARE=web

# Rate Limiting (optional customization):
# API_RATE_LIMIT=60
# AUTH_RATE_LIMIT=10
# SALES_IMPORT_RATE_LIMIT=30

# =============================================================================
# Phase 1 — Digital Library: Books Storage (MinIO)
# =============================================================================
BOOKS_STORAGE_DRIVER=s3
BOOKS_BUCKET=rizquna-books
BOOKS_SIGNED_URL_TTL=1800
BOOKS_PREVIEW_URL_TTL=3600
BOOKS_COVER_URL_TTL=3600
BOOKS_MAX_PDF_SIZE=209715200
BOOKS_MAX_COVER_SIZE=10485760
BOOKS_PREVIEW_PAGES=10

# Google OAuth (untuk Login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Google Workspace (untuk Sinkronisasi ERP)
# Masukkan JSON kredensial atau biarkan kosong jika menggunakan file storage/app/google/service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_COVERS_FOLDER_ID=
GOOGLE_DRIVE_PDFS_FOLDER_ID=
GOOGLE_SHEETS_LIBRARY_ID=

# =============================================================================
# Payment Gateway Configuration (Phase 3-6)
# =============================================================================
# Midtrans Payment Gateway
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=SB-Mid-client-placeholder
MIDTRANS_SERVER_KEY=SB-Mid-server-placeholder
MIDTRANS_IS_PRODUCTION=false
